<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>@ViewBag.Title</title>

    <link href="~/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/css/style.css" rel="stylesheet" />
</head>

<body>

<header>
<nav class="navbar navbar-expand-md navbar-dark bg-dark">

    <a class="navbar-brand" href="#">Pizza Hub</a>

    <button class="navbar-toggler"
            type="button"
            data-bs-toggle="collapse"
            data-bs-target="#navbarCollapse">

        <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarCollapse">

        <ul class="navbar-nav me-auto">

            <li class="nav-item">
                <a class="nav-link" asp-controller="Home" asp-action="Index">Головна</a>
            </li>

            <li class="nav-item">
                <a class="nav-link" href="/Food/List">Меню</a>
            </li>

            <li class="nav-item">
                <a class="nav-link" href="/Food/List/Pizza">Піца</a>
            </li>

            <li class="nav-item">
                <a class="nav-link" href="/Food/List/Drink">Напої</a>
            </li>
                        <li class="nav-item">
                <a class="nav-link" href="/Food/List/Combo">Комбо</a>
            </li>

            <li class="nav-item">
                <a class="nav-link" href="/PizzaCart/">Корзина</a>
            </li>

        </ul>

    </div>
</nav>
</header>

<div class="container mt-5">
    @RenderBody()
</div>

<footer class="container mt-5">
    <p>© 2026 Pizza Hub</p>
</footer>

<!-- ✅ BOOTSTRAP JS (ONLY ONE!) -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>