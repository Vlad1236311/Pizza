@model Pizza.Data.Models.AdminLogin

<h2>Вхід в адмін-панель</h2>

<form method="post">

    <input asp-for="Login"
           class="form-control"
           placeholder="Логін" />

    <br />

    <input asp-for="Password"
           type="password"
           class="form-control"
           placeholder="Пароль" />

    <br />

    <button class="btn btn-success">
        Увійти
    </button>

</form>

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger mt-3">
        @ViewBag.Error
    </div>
}